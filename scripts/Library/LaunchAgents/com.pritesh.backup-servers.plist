<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
   "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.pritesh.backup-servers</string>
    <key>ServiceDescription</key>
    <string>Run daily server backup</string>
    <key>ProgramArguments</key>
    <array>
      <string>/Users/pritesh/.local/bin/backup-servers.mts</string>
      <string>
      /Users/pritesh/.local/bin/backup-servers-config.json</string>
    </array>
    <key>RunAtLoad</key>
    <true />
    <key>StandardErrorPath</key>
    <string>/tmp/com.pritesh.backup-servers.err</string>
    <key>StandardOutPath</key>
    <string>/tmp/com.pritesh.backup-servers.out</string>
    <key>EnvironmentVariables</key>
    <dict>
      <key>NOTIFY</key>
      <string>/Users/pritesh/.local/bin/notify</string>
    </dict>
  </dict>
</plist>
