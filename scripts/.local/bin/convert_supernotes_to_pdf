#!/usr/bin/env bash

set -o pipefail

echo "$(date) Starting conversion..."

/Users/pritesh/.local/bin/supernote-toolkit \
  -input /Users/pritesh/Backups/supernote/Note/ \
  -output /Users/pritesh/Backups/supernote/PDFs

if [ $? -ne 0 ]; then
  echo "$(date) Conversion failed!"
  if [ $NOTIFY ]; then
    $NOTIFY "Supernotes conversion failed! Please check logs."
  fi
else
  echo "$(date) Conversion successful!"
  if [ $NOTIFY ]; then
    $NOTIFY "Supernotes converted successfully!"
  fi
fi
