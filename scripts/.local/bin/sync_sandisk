#!/usr/bin/env zsh

set -o pipefail

if [ $NOTIFY ]; then $NOTIFY "Syncing Sandisk"; fi

if [[ ! -e /Volumes/Sandisk ]]; then
  echo "Sandisk not mounted"
  exit
fi

rsync \
  --archive \
  --partial \
  --recursive \
  --delete \
  --exclude='.*' \
  $HOME/Documents \
  $HOME/Music \
  $HOME/Notes \
  $HOME/Pictures \
  $HOME/Ebooks \
  $HOME/Backups \
  $HOME/.dotfiles \
  /Volumes/Sandisk && diskutil unmount Sandisk

if [ $NOTIFY ]; then
  if [ $? -ne 0 ]; then
    $NOTIFY "Sandisk synced failed! Please check logs."
  else
    $NOTIFY "Sandisk synced successfully!"
  fi
fi

# To backup sensitive data, use:
#
# zip --encrypt ...
#
# For relatively convenient security.
