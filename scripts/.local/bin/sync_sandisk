#!/usr/bin/env zsh

set -o pipefail

if [[ ! -e /Volumes/Sandisk ]]; then
  echo "$(date) Sandisk not mounted!"
  exit
fi

echo "$(date) Starting sandisk sync..."
if [ $NOTIFY ]; then $NOTIFY "Syncing Sandisk"; fi

rsync \
  --archive \
  --partial \
  --recursive \
  --delete \
  --exclude='.*' \
  $HOME/Documents \
  $HOME/Music \
  $HOME/Notes \
  $HOME/Pictures \
  $HOME/Ebooks \
  $HOME/Backups \
  $HOME/.dotfiles \
  /Volumes/Sandisk && diskutil unmount Sandisk

if [ $? -ne 0 ]; then
  echo "$(date) Sandisk sync failed!"
  if [ $NOTIFY ]; then
    $NOTIFY "Sandisk synced failed! Please check logs."
  fi
else
  echo "$(date) Sandisk sync successful!"
  if [ $NOTIFY ]; then
    $NOTIFY "Sandisk synced successfully!"
  fi
fi

# To backup sensitive data, use:
#
# zip --encrypt ...
#
# For relatively convenient security.
