#!/usr/bin/env zsh

default_folders=(
  "$HOME/Music/English"
  "$HOME/Music/Classical"
  "$HOME/Music/Hindi"
  "$HOME/Music/Hindi Oldies"
  "$HOME/Music/Marathi"
  "$HOME/Music/Taylor Swift"
)

folders=(${@:-${default_folders[@]}})

((sleep 2 && cliamp next) &)

kitty --start-as minimized --detach  \
  /opt/homebrew/bin/cliamp --low-power --shuffle  "${folders[@]}"
